        "src/notion_brain.py",
        "src/slack_report.py"
      ],
      "role": "Pushes synthesized learnings into the 6 Notion Brain databases and posts an outbound Slack run summary. CLI/dashboard-triggered only, never from the Slack chat path."
    }
