      "files": [
        "src/main.py",
        "src/analyzer.py",
        "src/gemini_client.py",
        "src/taxonomy.py",
        "src/synthesizer.py"
      ],
      "role": "CLI-triggered only (never from Slack): downloads a reel, tags it via Gemini against the taxonomy, writes results back to the Sheet, and synthesizes learnings."
