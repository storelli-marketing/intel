# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_WORKSHEET_NAME=Sheet1
# Optional (Railway): base64 of the service-account JSON. If set, decoded at
# startup to GOOGLE_SERVICE_ACCOUNT_JSON_PATH (or /tmp/service-account.json
# when the path is blank).
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# Notion (optional; web trigger skips notion-sync if either is blank)
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# Web trigger — required to POST /run/social
RUN_SECRET=

# Default Storelli IG follower count, used when the sheet doesn't carry a
# per-row Followers column. Used to compute views/followers ratio -> PERFORMANCE.
STORELLI_IG_FOLLOWER_COUNT=170000
