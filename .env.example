# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_WORKSHEET_NAME=Sheet1
# Optional (Railway): base64 of the service-account JSON. If set, decoded at
# startup to GOOGLE_SERVICE_ACCOUNT_JSON_PATH (or /tmp/service-account.json
# when the path is blank).
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# Notion (optional; web trigger skips notion-sync if either is blank)
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# Web trigger — required to POST /run/social
RUN_SECRET=

# QA compiler pass: true (default) = 2 Gemini calls/row; false = 1 call/row
# (skips QA) to stretch a limited free-tier quota. CLI: --no-qa overrides.
QA_COMPILER_ENABLED=true

# Default Storelli IG follower count, used when the sheet doesn't carry a
# per-row Followers column. Used to compute views/followers ratio -> PERFORMANCE.
STORELLI_IG_FOLLOWER_COUNT=170000

# Slack bot — enables the interactive Marketing Brain in Slack.
# Create a Slack app, add bot scope `chat:write`, subscribe to `app_mention`,
# and point the Request URL at https://<railway-url>/slack/events.
# Missing values do not crash startup; /slack/events returns 503 until set.
# SLACK_WEBHOOK_URL above stays optional and unchanged (used for run reports).
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
